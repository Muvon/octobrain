# Octobrain benchmark configuration.
# Copy to .env, fill in your values, then `make longmemeval` (from benches/).
# Everything runs inside Docker — no host install required.

# ─── Chat LLM: agent answers + judge scoring ──────────────────────────────────
# Any OpenAI-compatible endpoint: Ollama Cloud, OpenAI, Together, Groq, etc.
# Both the agent (who answers from retrieved memory) and judge (who scores
# the answer) hit the same base URL — set JUDGE_MODEL different from
# AGENT_MODEL if you want a stronger judge.

AGENT_BASE_URL=https://ollama.example.com/v1
AGENT_API_KEY=sk-your-ollama-key

# Model that generates answers from retrieved memory context.
AGENT_MODEL=kimi-k2.6

# Judge model: scores answer correctness. LongMemEval's upstream scorer
# accepts only specific names without patching:
#   gpt-4o            ← what published SOTA papers (Mem0, ENGRAM) use — $5-15/full run
#   gpt-4o-mini       ← cost-aligned default — $0.30-1/full run, comparable scores
#   llama-3.1-70b-instruct  ← if you have a local server on :8001
JUDGE_MODEL=gpt-4o-mini

# Judge endpoint — defaults to OpenAI. Leave JUDGE_BASE_URL blank if using
# OpenAI directly. Override only if you want the judge to hit a different
# OpenAI-compatible endpoint (rare).
JUDGE_BASE_URL=
# Judge API key — leave blank to reuse OCTOBRAIN_EMBEDDING_API_KEY below.
# Set explicitly only if your judge key differs from your embedding key.
JUDGE_API_KEY=

# ─── Embedding: matches SOTA paper setups for apples-to-apples comparison ─────
# Mem0, ENGRAM, and the LongMemEval/LoCoMo leaderboard SOTA holders all use
# OpenAI's text-embedding-3-small. To compare against published numbers, use
# the same. Octobrain's openai embedding provider reads the standard env vars.
#
# Format is "provider:model". Examples:
#   openai:text-embedding-3-small  ← matches Mem0 / ENGRAM (recommended)
#   voyage:voyage-3.5-lite          ← if you have a Voyage key
#   openai:nomic-embed-text         ← if pointing OPENAI base at Ollama
OCTOBRAIN_EMBEDDING_MODEL=openai:text-embedding-3-small

# API key for the embedding provider. For openai:* this is your OpenAI key.
# Different from your chat key above — octobrain hits OpenAI directly for
# embeddings while the Python adapter hits Ollama Cloud for chat.
OCTOBRAIN_EMBEDDING_API_KEY=sk-your-openai-key

# Override the embedding endpoint (leave blank for the provider's default).
# Set this to point at Ollama Cloud's /v1/embeddings if you want a single
# provider for everything — but you lose the apples-to-apples comparison.
OCTOBRAIN_EMBEDDING_BASE_URL=

# ─── Benchmark selection ──────────────────────────────────────────────────────
# Which LongMemEval variant (filename without .json). Upstream's cleaned release
# ships three: longmemeval_oracle (no haystack — sanity check), longmemeval_s_cleaned
# (~115K tokens/instance, cheapest), longmemeval_m_cleaned (~500 sessions, larger).
LONGMEMEVAL_VARIANT=longmemeval_s_cleaned

# Octobrain config tuning during benchmark — leave defaults unless you know
# why you're changing them. Set to 1 to enable, 0 to disable.
OCTOBRAIN_HYDE_ENABLED=1
OCTOBRAIN_SLEEP_CONSOLIDATION=1

# Max questions to evaluate (set to a small number for smoke test, 0 = all).
MAX_QUESTIONS=0
